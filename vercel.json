{
  "installCommand": "cd sp-portal-react && npm ci",
  "buildCommand": "cd sp-portal-react && npm run build",
  "outputDirectory": "sp-portal-react/dist",
  "framework": "vite",
  "nodeVersion": "18.x",
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
